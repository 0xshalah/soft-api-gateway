# ─────────────────────────────────────────────────────────────────────────────
# File: .env.example
# Copy this file to .env and fill in your values before starting any service.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/soft_analytics?schema=public"

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL="localhost:6379"

# ── ClickHouse ─────────────────────────────────────────────────────────────
CLICKHOUSE_URL="http://localhost:8123"
CLICKHOUSE_DB="soft_analytics"

# ── NestJS Control Plane ───────────────────────────────────────────────────
PORT=3000
FRONTEND_URL="http://localhost:3001"

# ── Next.js Frontend ───────────────────────────────────────────────────────
NEXT_PUBLIC_CONTROL_PLANE_URL="http://localhost:3000"
NEXT_PUBLIC_WS_URL="http://localhost:3000"

# ── Go Data Plane ──────────────────────────────────────────────────────────
DATA_PLANE_PORT=8080
